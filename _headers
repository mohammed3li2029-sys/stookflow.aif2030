/*
  Security & caching headers for Cloudflare Pages.
  Cloudflare Pages reads this file automatically — no configuration needed.
*/

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' https://esm.sh; connect-src 'self' https://*.supabase.co https://esm.sh

/js/chart.umd.min.js
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=3600

/js/*
  Cache-Control: public, max-age=3600
